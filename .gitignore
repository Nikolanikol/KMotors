# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.env.local
.env.*.local
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.csv

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code worktrees (служебные папки, не коммитить)
.claude/worktrees/

# Секретные ключи Google
*.json
!package.json
!package-lock.json
!tsconfig*.json
!next.config*.json

# Parts-image pipeline runtime artifacts
scripts/.*.log
scripts/lib/__pycache__/
_debrand_preview/
_holefix_preview/
