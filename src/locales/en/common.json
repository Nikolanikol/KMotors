      },
      "step3": {
        "title": "Inspection and Check",
        "description": "Our specialist conducts a full inspection of the car in South Korea. You'll receive a photo and video report with all details."
      },
      "step4": {
        "title": "Pay the Balance",
        "description": "After confirmation, pay the remaining amount. We'll purchase the car and start preparing it for export."
      },
      "step5": {
        "title": "Customs Processing",
        "description": "Our team handles all customs procedures. The car is processed for export to Russia with all necessary documents."
      },
      "step6": {
        "title": "Delivery to Russia",
        "description": "The car is shipped to Russia by sea. We track every stage of delivery and keep you informed.",
        "highlight": "Delivery to Vladivostok typically takes 7-14 days depending on the destination."
      },
      "step7": {
        "title": "Customs Clearance",
        "description": "Upon arrival in Russia, we assist with customs clearance. All fees and taxes are paid according to Russian legislation."
      },
      "step8": {
        "title": "Receive Your Car",
        "description": "Your car is ready for pickup! We'll hand over the car with all necessary documents and keys.",
        "highlight": "Congratulations! Your new car is now ready to use."
      }
